# V Mailchimpu: Profile > Extras > API keys
MAILCHIMP_API_KEY=vas_mailchimp_api_klic

# Poslední část API klíče, např. us21
MAILCHIMP_SERVER_PREFIX=us21

# Povolený frontend při lokálním vývoji
FRONTEND_ORIGIN=http://localhost:5173

PORT=5000
FLASK_DEBUG=1

# Povinné pro veřejné nasazení; ponechte prázdné pouze při lokálním vývoji
APP_USERNAME=admin
APP_PASSWORD=zvolte_silne_nahodne_heslo
